# Vercel Environment Variables Template
# Copy to .env.local for development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_KEY
NEXT_PUBLIC_GEMINI_API_KEY=YOUR_GEMINI_KEY
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-minimum-32-characters-long

# Backend  
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/lifechain
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-jwt-secret-minimum-32-characters-long
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=whatsapp:your-twilio-phone-number
TWILIO_WEBHOOK_URL=http://localhost:3001/api/v1/whatsapp/webhook
GEMINI_API_KEY=YOUR_GEMINI_KEY
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_KEY
HARDWARE_SECRET_TOKEN=hardware-secret-token
